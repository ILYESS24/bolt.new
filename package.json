{
  "name": "project-builder",
  "version": "1.0.0",
  "description": "A modern web application for creating and managing projects",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "check-env": "node scripts/check-env.js",
    "deploy": "node scripts/deploy.sh",
    "deploy:vercel": "node scripts/deploy-vercel.sh",
    "deploy:github": "bash scripts/deploy-github.sh",
    "setup:github": "bash scripts/setup-github.sh",
    "verify": "ts-node scripts/verify-boltai.ts",
    "auto-deploy": "ts-node scripts/auto-deploy-github.ts",
    "build:prod": "npm run check-env && npm run db:generate && npm run build",
    "postinstall": "prisma generate",
    "db:switch": "node scripts/switch-db.js",
    "db:sqlite": "npm run db:switch sqlite",
    "db:postgres": "npm run db:switch postgresql",
    "studio": "next dev -p 3001",
    "build:studio": "next build",
    "fix:errors": "node scripts/fix-all-errors.js",
    "verify:studio": "npm run build:studio && npm run lint"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.8",
    "@heroicons/react": "^2.2.0",
    "@monaco-editor/react": "^4.6.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.7.1",
    "@reactflow/background": "^11.3.14",
    "@reactflow/controls": "^11.2.14",
    "@reactflow/core": "^11.11.4",
    "@reactflow/minimap": "^11.7.14",
    "@reactflow/node-toolbar": "^1.3.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/diff": "^7.0.2",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^9.0.7",
    "@webcontainer/api": "^1.6.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "ai": "^2.2.30",
    "autoprefixer": "^10.4.16",
    "bcryptjs": "^2.4.3",
    "diff": "^8.0.2",
    "file-saver": "^2.0.5",
    "framer-motion": "^10.18.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.294.0",
    "monaco-editor": "^0.45.0",
    "next": "^14.0.4",
    "next-auth": "^4.24.5",
    "openai": "^4.20.1",
    "postcss": "^8.4.32",
    "prisma": "^5.7.1",
    "react": "^18.2.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.2.0",
    "react-flow": "^1.0.3",
    "react-hot-toast": "^2.4.1",
    "react-split": "^2.0.14",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "uuid": "^9.0.1",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@types/node": "^20.10.5",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.0.4",
    "ts-node": "^10.9.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}